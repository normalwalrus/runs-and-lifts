# Password required to log in to the app
APP_PASSWORD=
# 64 random hex chars, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=
# Local dev: file:./data/fitness.db  ·  Production: libsql://<db-name>-<org>.turso.io
DATABASE_URL=file:./data/fitness.db
# Only needed when DATABASE_URL points at Turso
TURSO_AUTH_TOKEN=
