# Password required to log in to the app
APP_PASSWORD=
# 64 random hex chars, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=
# Local dev (npm run db:local): postgres://postgres:postgres@127.0.0.1:5433/postgres
# Production: your Postgres connection string (e.g. Neon)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/postgres
